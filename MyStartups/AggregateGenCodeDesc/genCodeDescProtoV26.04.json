{
    "_description": "fromCodeAgent(such as HuayanCoder)_toCodeReviewSystem(such as BugLess)",
    "_summarySemantics": {
        "totalCodeLines": "Count only the code lines represented by this record. Do not include deleted historical lines.",
        "fullGeneratedCodeLines": "Subset of represented code lines whose genRatio is 100.",
        "partialGeneratedCodeLines": "Subset of represented code lines whose genRatio is greater than 0 and less than 100."
    },
    "_blameSemantics": {
        "blame": "VCS blame attribution recorded at write time by the codeAgent for each described line or range.",
        "blame.revisionId": "[mandatory] The VCS commit SHA (git) or revision number (svn) that last introduced the current form of this line.",
        "blame.originalFilePath": "[mandatory] The file path inside the repository where this line originated (may differ from fileName due to renames or moves).",
        "blame.originalLine": "[mandatory] The line number inside originalFilePath at the originating revision.",
        "blame.timestamp": "[mandatory] ISO 8601 UTC timestamp of the originating revision. Enables AlgA/AlgC startTime~endTime filtering without live repository access.",
        "blame.author": "[optional] The committer identity (email or username) of the originating revision."
    },
    "_detailSemantics": {
        "completeness": "For AlgC (offline, no repository access), DETAIL must be exhaustive: every surviving line in the file must be listed, including human-written lines as genRatio=0 / genMethod=Manual. This makes the genCodeDesc self-sufficient to reproduce the same result as AlgA/AlgB.",
        "manual": "genRatio=0 with genMethod=Manual represents a human-written line. It must carry a blame entry identical in structure to AI-generated lines.",
        "lineRange_constraint": "A lineRange entry (including Manual ones) is only valid when all lines in that range share the same blame origin (same revisionId, originalFilePath, and a contiguous originalLine block). Lines with different blame origins must each have their own lineLocation entry."
    },

